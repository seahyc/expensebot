# Anthropic
# Used only for managed-tier users; BYOK users supply their own.
MAINTAINER_ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Lark (Open Platform)
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# Postgres
DATABASE_URL=postgresql://expensebot:expensebot@localhost:5432/expensebot

# Redis
REDIS_URL=redis://localhost:6379/0

# Encryption (for API keys + refresh tokens at rest)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# Stripe (managed tier billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MANAGED=

# Email inbox (for forwarding receipts)
# Domain you control with MX pointing to inbound webhook provider
INBOUND_EMAIL_DOMAIN=in.expensebot.example
POSTMARK_INBOUND_TOKEN=

# S3 (24h receipt cache)
S3_BUCKET=expensebot-receipts
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backend public URL (for extension CORS + OAuth callbacks)
PUBLIC_BASE_URL=https://expensebot.example

# OmniHR
OMNIHR_API_BASE=https://api.omnihr.co/api/v1
